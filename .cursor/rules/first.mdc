## Code Quality Standards

### Critical Rules - NEVER VIOLATE

1. **NO Deprecated APIs**
   - NEVER use deprecated functions or classes
   - Always use the latest recommended alternatives
   - Check deprecation status before implementation

2. **Proper State Management**
   ```kotlin
   // CORRECT - Use StateFlow with sealed classes
   sealed class UiState<out T> {
       data object Loading : UiState<Nothing>()
       data class Success<T>(val data: T) : UiState<T>()
       data class Error(val message: String) : UiState<Nothing>()
   }
   
   // ViewModel
   private val _uiState = MutableStateFlow<UiState<List<Task>>>(UiState.Loading)
   val uiState: StateFlow<UiState<List<Task>>> = _uiState.asStateFlow()
   ```

3. **Compose Best Practices**
   ```kotlin
   // CORRECT - Stable parameters, proper state hoisting
   @Composable
   fun TaskCard(
       task: Task,
       onTaskClick: (String) -> Unit,
       modifier: Modifier = Modifier
   ) {
       // Use remember for computed values
       val progress = remember(task.checklist) { 
           calculateProgress(task.checklist) 
       }
       // Implementation
   }
   
   // WRONG - Avoid
   @Composable
   fun TaskCard(task: Task, viewModel: TaskViewModel) { } // Don't pass ViewModels
   ```

4. **Database - Room Best Practices**
   ```kotlin
   // CORRECT - Use Flow for reactive queries
   @Dao
   interface TaskDao {
       @Query("SELECT * FROM tasks WHERE section = :section")
       fun getTasksBySection(section: String): Flow<List<TaskEntity>>
       
       @Upsert // Use Upsert instead of separate insert/update
       suspend fun upsertTask(task: TaskEntity)
   }
   
   // Use Type Converters for complex types
   @TypeConverter
   fun fromLabelList(labels: List<Label>): String = Json.encodeToString(labels)
   ```

5. **Coroutine Scoping**
   ```kotlin
   // CORRECT - Use appropriate scopes
   class TaskViewModel @Inject constructor(
       private val repository: TaskRepository
   ) : ViewModel() {
       
       fun loadTasks() {
           viewModelScope.launch {
               repository.getTasks()
                   .catch { emit(UiState.Error(it.message)) }
                   .collect { tasks ->
                       _uiState.value = UiState.Success(tasks)
                   }
           }
       }
   }
   ```

6. **Dependency Injection with Hilt**
   ```kotlin
   // CORRECT - Proper Hilt setup
   @HiltAndroidApp
   class TaskApp : Application()
   
   @Module
   @InstallIn(SingletonComponent::class)
   object DatabaseModule {
       @Provides
       @Singleton
       fun provideDatabase(@ApplicationContext context: Context): TaskDatabase {
           return Room.databaseBuilder(context, TaskDatabase::class.java, "task_db")
               .fallbackToDestructiveMigration()
               .build()
       }
   }
   ```

7. **Navigation**
   ```kotlin
   // CORRECT - Type-safe navigation
   sealed class Screen(val route: String) {
       object Kanban : Screen("kanban")
       object Notes : Screen("notes")
       data object TaskDetail : Screen("task/{taskId}") {
           fun createRoute(taskId: String) = "task/$taskId"
       }
   }
   ```

8. **Error Handling**
   ```kotlin
   // CORRECT - Proper error handling
   suspend fun loadTasks(): Result<List<Task>> = runCatching {
       taskDao.getAllTasks().first()
   }.fold(
       onSuccess = { Result.success(it.map { entity -> entity.toDomain() }) },
       onFailure = { Result.failure(it) }
   )
   ```

