## Testing Requirements

```kotlin
// ViewModel Test Example
@Test
fun `loadTasks emits success state with tasks`() = runTest {
    // Given
    val tasks = listOf(Task(id = "1", title = "Test"))
    coEvery { repository.getTasks() } returns flowOf(tasks)
    
    // When
    viewModel.loadTasks()
    
    // Then
    viewModel.uiState.test {
        assert(awaitItem() is UiState.Success)
    }
}
