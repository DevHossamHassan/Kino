/**
 * Breaks down a task into smaller actionable steps using ML model.
 * 
 * @param task The task to analyze
 * @param dueDate The task's due date
 * @return List of suggested micro-tasks ordered by priority
 * @throws TaskAnalysisException if ML model fails
 */
suspend fun analyzeTaskBreakdown(task: Task, dueDate: LocalDateTime): List<MicroTask>
