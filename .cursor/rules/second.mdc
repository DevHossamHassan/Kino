### API-Style Communication Between Features

**Example: Kanban Feature API**

```kotlin
// feature/kanban/api/KanbanApi.kt
interface KanbanApi {
    /**
     * Get task by ID (for deep linking from other features)
     */
    suspend fun getTask(taskId: String): Result<Task>
    
    /**
     * Create a task from external feature
     */
    suspend fun createTask(task: TaskCreationRequest): Result<String>
    
    /**
     * Navigate to task detail
     */
    fun navigateToTaskDetail(navController: NavController, taskId: String)
    
    /**
     * Get observable task updates (for notifications)
     */
    fun observeTaskUpdates(): Flow<TaskUpdate>
}

// feature/kanban/api/KanbanNavigation.kt
object KanbanDestinations {
    const val KANBAN_BOARD = "kanban_board"
    const val TASK_DETAIL = "task_detail/{taskId}"
    
    fun taskDetailRoute(taskId: String) = "task_detail/$taskId"
}

// Internal implementation (NOT exposed)
// feature/kanban/internal/data/repository/KanbanApiImpl.kt
@Singleton
internal class KanbanApiImpl @Inject constructor(
    private val taskRepository: TaskRepository,
    private val taskDao: TaskDao
) : KanbanApi {
    
    override suspend fun getTask(taskId: String): Result<Task> = 
        runCatching { taskRepository.getTaskById(taskId) }
    
    override suspend fun createTask(task: TaskCreationRequest): Result<String> =
        runCatching { taskRepository.createTask(task) }
        
    override fun navigateToTaskDetail(navController: NavController, taskId: String) {
        navController.navigate(KanbanDestinations.taskDetailRoute(taskId))
    }
    
    override fun observeTaskUpdates(): Flow<TaskUpdate> = 
        taskDao.observeAllTasks().map { it.toTaskUpdates() }
}
```

**Example: Notes Feature Using Kanban API**

```kotlin
// feature/notes/internal/presentation/viewmodel/NoteViewModel.kt
@HiltViewModel
internal class NoteViewModel @Inject constructor(
    private val noteRepository: NoteRepository,
    private val kanbanApi: KanbanApi  // ← Dependency on API, not implementation
) : ViewModel() {
    
    fun attachNoteToTask(noteId: String, taskId: String) {
        viewModelScope.launch {
            kanbanApi.getTask(taskId).fold(
                onSuccess = { task ->
                    // Attach note to task
                    noteRepository.linkNoteToTask(noteId, taskId)
                },
                onFailure = { error ->
                    // Handle error
                }
            )
        }
    }
}
```

